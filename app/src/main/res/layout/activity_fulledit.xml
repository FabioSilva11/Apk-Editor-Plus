<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/full_edit_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/full_edit_surface"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="30dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="4dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/apk_icon"
            android:layout_width="37dp"
            android:layout_height="37dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/apk_icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/apk_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="@color/full_edit_text_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/apk_package"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/full_edit_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/action_webserver_button"
            android:layout_width="37dp"
            android:layout_height="37dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/web_server"
            android:padding="8dp"
            android:src="@drawable/ic_www"
            android:tint="@color/full_edit_text_primary" />

        <ImageButton
            android:id="@+id/action_patch_button"
            android:layout_width="37dp"
            android:layout_height="37dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/patch"
            android:padding="8dp"
            android:src="@drawable/dg_patch"
            android:tint="@color/full_edit_text_primary" />

        <TextView
            android:id="@+id/action_build_button"
            android:layout_width="82dp"
            android:layout_height="37dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/full_edit_primary_pill"
            android:clickable="true"
            android:fontFamily="sans-serif-medium"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/build"
            android:textColor="@color/full_edit_accent_on"
            android:textSize="12sp" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never" />

    <LinearLayout
        android:id="@+id/bottom_tabs_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tab_string"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/full_edit_tab_background"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/string"
            android:textColor="@color/full_edit_tab_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tab_files"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/full_edit_tab_background"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/files"
            android:textColor="@color/full_edit_tab_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tab_manifest"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/full_edit_tab_background"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/manifest"
            android:textColor="@color/full_edit_tab_text"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>

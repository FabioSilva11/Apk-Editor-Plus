<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===================== -->
    <!-- TEMA BASE COM TOOLBAR -->
    <!-- ===================== -->

    <style name="Theme.MyApp" parent="Theme.Material3.Light">

        <!-- Cores principais -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>

        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>

        <!-- Fundo e superfícies -->
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>

        <!-- Estados -->
        <item name="colorError">@color/md_theme_light_error</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Toolbar -->
        <item name="toolbarStyle">@style/Widget.MyApp.Toolbar</item>

        <!-- Botões -->
        <item name="materialButtonStyle">@style/Widget.MyApp.Button</item>

        <!-- TextInput -->
        <item name="textInputStyle">@style/Widget.MyApp.TextInputLayout</item>
 
        <!-- Cards -->
        <item name="materialCardViewStyle">@style/Widget.MyApp.Card</item>
        
        <!-- Cores de texto -->
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorSecondaryNoDisable">?attr/colorOnSurfaceVariant</item>

        <!-- ActionBar e Menu -->
        <item name="actionBarTheme">@style/ThemeOverlay.MyApp.ActionBar</item>
        <item name="actionBarPopupTheme">@style/ThemeOverlay.Material3.Light</item>

        <!-- Atributos Legado Mapeados para M3 -->
        <item name="iconPrimary">?attr/colorOnSurface</item>
        <item name="iconSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="navActivated">?attr/colorPrimary</item>
        <item name="navNormal">?attr/colorOnSurfaceVariant</item>
        <item name="navSolid">@color/md_theme_light_primaryContainer</item>
        <item name="navStroke">#20000000</item>
        <item name="navStroked">@color/md_theme_light_primary</item>
        <item name="navRipple">#10000000</item>
        <item name="bottomBar">?attr/colorSurfaceVariant</item>
        <item name="card">?attr/colorSurfaceVariant</item>
        <item name="separator">?attr/colorOutlineVariant</item>

        <!-- Bottom Navigation Style -->
        <item name="bottomNavigationStyle">@style/Widget.MyApp.BottomNavigationView</item>

    </style>


    <!-- ===================== -->
    <!-- TEMA SEM TOOLBAR -->
    <!-- ===================== -->

    <style name="Theme.MyApp.NoToolbar" parent="Theme.Material3.Light">

        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="android:colorBackground">@color/md_theme_light_background</item>

    </style>


    <!-- ===================== -->
    <!-- WIDGETS CUSTOM -->
    <!-- ===================== -->

    <!-- Toolbar -->
    <style name="Widget.MyApp.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorSurface</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="navigationIconTint">?attr/colorOnSurface</item>
        <item name="actionMenuTextColor">?attr/colorOnSurface</item>
    </style>

    <!-- Botões -->
    <style name="Widget.MyApp.Button" parent="Widget.Material3.Button" />

    <style name="Widget.MyApp.Button.TextButton" parent="Widget.Material3.Button.TextButton">
        <!-- Herdando comportamento de M3 TextButton -->
    </style>

    <style name="Widget.MyApp.Button.TonalButton" parent="Widget.Material3.Button.TonalButton">
        <!-- Herdando comportamento de M3 TonalButton -->
    </style>

    <style name="Widget.MyApp.Button.ElevatedButton" parent="Widget.Material3.Button.ElevatedButton">
        <!-- Herdando comportamento de M3 ElevatedButton -->
    </style>

    <style name="Widget.MyApp.Button.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <!-- Herdando comportamento de M3 OutlinedButton -->
    </style>

    <style name="Widget.MyApp.Button.IconButton" parent="Widget.Material3.Button.IconButton">
        <!-- Herdando comportamento de M3 IconButton -->
    </style>

    <!-- Cards -->
    <style name="Widget.MyApp.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/md_theme_light_surface</item>
    </style>

    <style name="Widget.MyApp.Card.Elevated" parent="Widget.MyApp.Card" />

    <style name="Widget.MyApp.Card.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/md_theme_light_surfaceVariant</item>
    </style>

    <style name="Widget.MyApp.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/md_theme_light_surface</item>
    </style>

    <!-- Inputs -->
    <style name="Widget.MyApp.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_theme_light_primary</item>
        <item name="hintTextColor">@color/md_theme_light_onSurfaceVariant</item>
    </style>

    <style name="Widget.MyApp.TextInputLayout.Filled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/md_theme_light_surfaceVariant</item>
    </style>

    <!-- Overlay para ActionBar -->
    <style name="ThemeOverlay.MyApp.ActionBar" parent="ThemeOverlay.Material3.ActionBar">
        <item name="colorControlNormal">?attr/colorOnSurface</item>
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="actionMenuTextColor">?attr/colorOnSurface</item>
    </style>
    
    <!-- Navigation Bar Style (Material 3 with Indicator) -->
    <style name="Widget.MyApp.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bnv_item_color</item>
        <item name="itemTextColor">@color/bnv_item_color</item>
        <item name="itemIconSize">22dp</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

</resources>
